# ── Server ───────────────────────────────────────────────
SERVER_PORT=8080

# ── Database ─────────────────────────────────────────────
DB_HOST=mysqldb
DB_PORT=3306
DB_NAME=library_db
DB_USERNAME=library_user
DB_PASSWORD=change_me

MYSQL_ROOT_PASSWORD=change_me_root

# ── JPA ──────────────────────────────────────────────────
# update  → auto-apply schema changes (dev/staging)
# validate → only validate schema, never change it (production)
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ── JWT ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION_MS=1800000
